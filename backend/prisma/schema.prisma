generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]

  @@map("roles")
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  passwordHash     String            @map("password_hash")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  cnpj             String?           @unique
  cpf              String?           @unique
  roleId           Int               @map("role_id")
  username         String            @unique
  appointments     Appointment[]
  specialties      DoctorSpecialty[]
  notasFiscais     NotaFiscal[]      @relation("NotaFiscalCreator")
  patientHistories PatientHistory[]  @relation("DoctorHistories")
  transactions     Transaction[]     @relation("TransactionCreator")
  role             Role              @relation(fields: [roleId], references: [id])

  resetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

model Patient {
  id               String           @id @default(uuid())
  name             String
  email            String?          @unique
  phone            String?
  cpf              String?          @unique
  dateOfBirth      DateTime?        @map("date_of_birth")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  additionalInfo   String?          @map("additional_info")
  city             String?
  state            String?
  street           String?
  streetNumber     String?          @map("street_number")
  zipCode          String?          @map("zip_code")
  agreement        String?
  gender           String?
  appointments     Appointment[]
  medicalRecords   MedicalRecord[]
  notasFiscais     NotaFiscal[]
  patientHistories PatientHistory[]
  transactions     Transaction[]

  @@map("patients")
}

model Specialty {
  id           String            @id @default(uuid())
  name         String            @unique
  appointments Appointment[]
  doctors      DoctorSpecialty[]

  @@map("specialties")
}

model DoctorSpecialty {
  doctorId    String
  specialtyId String
  doctor      User      @relation(fields: [doctorId], references: [id])
  specialty   Specialty @relation(fields: [specialtyId], references: [id])

  @@id([doctorId, specialtyId])
  @@map("doctor_specialties")
}

model Appointment {
  id               String            @id @default(uuid())
  userId           String            @map("user_id")
  patientId        String            @map("patient_id")
  scheduledAt      DateTime          @map("scheduled_at")
  status           AppointmentStatus @default(SCHEDULED)
  notes            String?
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  medico           String?
  address          String?
  meetingLink      String?           @map("meeting_link")
  roomId           String?           @map("room_id")
  specialtyId      String?           @map("specialty_id")
  type             AppointmentType   @default(IN_PERSON)
  patient          Patient           @relation(fields: [patientId], references: [id])
  specialty        Specialty?        @relation(fields: [specialtyId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  medicalRecord    MedicalRecord?
  notasFiscais     NotaFiscal[]
  patientHistories PatientHistory[]
  transactions     Transaction[]

  @@map("appointments")
}

model MedicalRecord {
  id            String       @id @default(uuid())
  appointmentId String?      @unique @map("appointment_id")
  patientId     String       @map("patient_id")
  diagnosis     String?
  prescription  String?
  notes         String?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  patient       Patient      @relation(fields: [patientId], references: [id])

  @@map("medical_records")
}

model PatientHistory {
  id            String             @id @default(uuid())
  patientId     String             @map("patient_id")
  doctorId      String             @map("doctor_id")
  appointmentId String?            @map("appointment_id")
  type          PatientHistoryType
  title         String
  description   String
  attachments   String[]           @default([])
  deletedAt     DateTime?          @map("deleted_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  appointment   Appointment?       @relation(fields: [appointmentId], references: [id])
  doctor        User               @relation("DoctorHistories", fields: [doctorId], references: [id])
  patient       Patient            @relation(fields: [patientId], references: [id])

  @@map("patient_history")
}

model FinancialAccount {
  id                   String        @id @default(uuid())
  name                 String
  type                 AccountType
  bank                 String?
  initialBalance       Decimal       @default(0) @map("initial_balance") @db.Decimal(10, 2)
  currency             String        @default("BRL")
  isActive             Boolean       @default(true) @map("is_active")
  isDefault            Boolean       @default(false) @map("is_default")
  color                String?
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  pluggyAccountId      String?       @unique @map("pluggy_account_id")
  transactions         Transaction[] @relation("AccountTransactions")
  transferTransactions Transaction[] @relation("TransferTarget")

  @@map("financial_accounts")
}

model PluggyItem {
  id            String    @id @default(uuid())
  pluggyItemId  String    @unique @map("pluggy_item_id")
  connectorName String    @map("connector_name")
  connectorLogo String?   @map("connector_logo")
  status        String    @default("UPDATED")
  lastSync      DateTime? @map("last_sync")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("pluggy_items")
}

model FinancialCategory {
  id           String              @id @default(uuid())
  name         String
  type         CategoryType
  color        String?
  icon         String?
  parentId     String?             @map("parent_id")
  isDefault    Boolean             @default(false) @map("is_default")
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  parent       FinancialCategory?  @relation("CategoryParent", fields: [parentId], references: [id])
  children     FinancialCategory[] @relation("CategoryParent")
  transactions Transaction[]

  @@map("financial_categories")
}

model Employee {
  id           String         @id @default(uuid())
  name         String
  cpf          String?        @unique
  email        String?        @unique
  phone        String?
  position     String
  department   String?
  hireDate     DateTime?      @map("hire_date")
  salary       Decimal?       @db.Decimal(10, 2)
  status       EmployeeStatus @default(ACTIVE)
  dateOfBirth  DateTime?      @map("date_of_birth")
  gender       String?
  street       String?
  streetNumber String?        @map("street_number")
  city         String?
  state        String?
  zipCode      String?        @map("zip_code")
  notes        String?
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@map("employees")
}

model NotaFiscal {
  id            String           @id @default(uuid())
  numero        String           @unique
  patientId     String           @map("patient_id")
  appointmentId String?          @map("appointment_id")
  transactionId String?          @map("transaction_id")
  createdBy     String           @map("created_by")
  servico       String
  valor         Decimal          @db.Decimal(10, 2)
  status        NotaFiscalStatus @default(PENDENTE)
  dataEmissao   DateTime?        @map("data_emissao")
  pdfUrl        String?          @map("pdf_url")
  observacoes   String?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  appointment   Appointment?     @relation(fields: [appointmentId], references: [id])
  createdByUser User             @relation("NotaFiscalCreator", fields: [createdBy], references: [id])
  patient       Patient          @relation(fields: [patientId], references: [id])
  transaction   Transaction?     @relation(fields: [transactionId], references: [id])

  @@map("notas_fiscais")
}

model Transaction {
  id                  String            @id @default(uuid())
  accountId           String            @map("account_id")
  categoryId          String            @map("category_id")
  patientId           String?           @map("patient_id")
  appointmentId       String?           @map("appointment_id")
  createdBy           String            @map("created_by")
  type                TransactionType
  amount              Decimal           @db.Decimal(10, 2)
  description         String
  status              TransactionStatus @default(PENDING)
  paymentMethod       PaymentMethod     @default(OTHER) @map("payment_method")
  dueDate             DateTime          @map("due_date")
  paidAt              DateTime?         @map("paid_at")
  reference           String?
  isRecurring         Boolean           @default(false) @map("is_recurring")
  recurringGroupId    String?           @map("recurring_group_id")
  installmentNumber   Int?              @map("installment_number")
  totalInstallments   Int?              @map("total_installments")
  transferToAccountId String?           @map("transfer_to_account_id")
  tags                String[]          @default([])
  attachmentUrl       String?           @map("attachment_url")
  deletedAt           DateTime?         @map("deleted_at")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  notasFiscais        NotaFiscal[]
  account             FinancialAccount  @relation("AccountTransactions", fields: [accountId], references: [id])
  appointment         Appointment?      @relation(fields: [appointmentId], references: [id])
  category            FinancialCategory @relation(fields: [categoryId], references: [id])
  createdByUser       User              @relation("TransactionCreator", fields: [createdBy], references: [id])
  patient             Patient?          @relation(fields: [patientId], references: [id])
  transferToAccount   FinancialAccount? @relation("TransferTarget", fields: [transferToAccountId], references: [id])

  @@map("transactions")
}

model EmpresaConfig {
  id                 String   @id(map: "EmpresaConfig_pkey") @default(uuid())
  razaoSocial        String
  cnpj               String
  inscricaoMunicipal String
  municipioCodigo    String
  nfeLogin           String
  nfeSenha           String
  nfeAmbiente        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("empresa_config")
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  CONFIRMED
  IN_PROGRESS
  CANCELED
  NO_SHOW
}

enum AppointmentType {
  IN_PERSON
  ONLINE
  HOME_CARE
}

enum PatientHistoryType {
  CONSULTA
  EXAME
  PRESCRICAO
  OBSERVACAO
  SOLICITACAO
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PIX
  BANK_TRANSFER
  INSURANCE
  OTHER
}

enum AccountType {
  CHECKING
  SAVINGS
  CASH
  CREDIT_CARD
  INVESTMENT
}

enum CategoryType {
  INCOME
  EXPENSE
  BOTH
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  entity     String
  entityId   String?  @map("entity_id")
  before     Json?    @map("before")
  after      Json?    @map("after")
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

enum NotaFiscalStatus {
  PENDENTE
  PROCESSANDO
  ERRO
  EMITIDA
  CANCELADA
}

model SusProcedure {
  id         String   @id @default(uuid())
  codigo     String   @unique
  nome       String
  modalidade String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("sus_procedures")
}
